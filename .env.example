# ─────────────────────────────────────────────
# Kolo Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=kolo_db

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_256_bit_hex_string
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Paystack ──────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_test_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# ── Termii (SMS) ──────────────────────────────
# Get from https://termii.com/account/api
TERMII_API_KEY=your_termii_api_key_here
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_SENDER_ID=Kolo

# ── App ───────────────────────────────────────
APP_BASE_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=dev
